# --- database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mailtro
DB_SSLMODE=disable

# --- api ---
PORT=3000
JWT_SECRET=change-me-in-production

# --- rabbitmq (shared with box smtp) ---
AMQP_HOST=localhost
AMQP_PORT=5672
AMQP_USER=mailtro
AMQP_PASSWORD=mailtro

# --- box queue names ---
QUEUE_RECEIVER=box-receiver-1
QUEUE_SENDER=box-sender-1
QUEUE_STATUS=box-status-1

# --- mail platform DNS identity ---
# MX hosts users must add on their domain; separate multiple with ';'
MX_HOSTS=smtp.mailtro.site
# root SPF include users must add (v=spf1 include:<this> ~all)
SPF_INCLUDE=_spf.mailtro.site
# CNAME target zone for domain ownership verification (_mailtro.<domain> -> <token>.<zone>)
VERIFY_ZONE=verify.mailtro.site
# primary mail server hostname (used in Message-ID)
MAIL_HOSTNAME=smtp.mailtro.site

# --- delivery retry ---
RETRY_DELAY_MINUTES=6
MAX_RETRIES=5
