# Copy to .env next to the compose files and adjust.

# --- database ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mailtro

# --- api ---
JWT_SECRET=change-me-in-production

# --- rabbitmq (must match box.yml on the mail server) ---
AMQP_USER=mailtro
AMQP_PASSWORD=mailtro

# --- box queue names (must match box.yml) ---
QUEUE_RECEIVER=box-receiver-1
QUEUE_SENDER=box-sender-1
QUEUE_STATUS=box-status-1

# --- DNS identity shown to users ---
# multiple MX hosts separated by ';' (e.g. smtp.mailtro.site;smtp2.mailtro.site)
MX_HOSTS=smtp.mailtro.site
SPF_INCLUDE=_spf.mailtro.site
VERIFY_ZONE=verify.mailtro.site
MAIL_HOSTNAME=smtp.mailtro.site

# --- delivery retry ---
RETRY_DELAY_MINUTES=6
MAX_RETRIES=5

# --- frontend (baked at build time) ---
VITE_API_BASE_URL=http://localhost:3000/api
